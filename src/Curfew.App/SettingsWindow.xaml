<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Curfew.App.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel Padding="28" Spacing="12" MaxWidth="520" HorizontalAlignment="Center">
            <TextBlock Text="Curfew Settings" FontSize="26" FontWeight="Bold" />

            <TextBlock Text="Daily time limits (minutes)" FontWeight="SemiBold" Margin="0,8,0,0" />
            <StackPanel x:Name="DailyLimitsPanel" Spacing="6" />

            <TextBlock Text="Warnings" FontWeight="SemiBold" Margin="0,8,0,0" />
            <Grid ColumnSpacing="10" RowSpacing="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Text="First (min)" VerticalAlignment="Center" Grid.Row="0" Grid.Column="0" />
                <NumberBox x:Name="Warn1Min" Minimum="0" Maximum="600" Grid.Row="0" Grid.Column="1" />
                <TextBox x:Name="Warn1Msg" PlaceholderText="message" Grid.Row="0" Grid.Column="2" />
                <TextBlock Text="Second (min)" VerticalAlignment="Center" Grid.Row="1" Grid.Column="0" />
                <NumberBox x:Name="Warn2Min" Minimum="0" Maximum="600" Grid.Row="1" Grid.Column="1" />
                <TextBox x:Name="Warn2Msg" PlaceholderText="message" Grid.Row="1" Grid.Column="2" />
            </Grid>

            <TextBlock Text="Blocking message" FontWeight="SemiBold" Margin="0,8,0,0" />
            <TextBox x:Name="BlockingMsg" />

            <TextBlock Text="Lock screen" FontWeight="SemiBold" Margin="0,8,0,0" />
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="Shutdown timeout (min)" VerticalAlignment="Center" />
                <NumberBox x:Name="LockTimeout" Minimum="1" Maximum="720" Width="120" />
            </StackPanel>

            <TextBlock Text="Idle detection" FontWeight="SemiBold" Margin="0,8,0,0" />
            <CheckBox x:Name="IdleEnabled" Content="Auto-pause when idle" />
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="Idle timeout (min)" VerticalAlignment="Center" />
                <NumberBox x:Name="IdleTimeout" Minimum="1" Maximum="600" Width="120" />
            </StackPanel>

            <TextBlock Text="Content filtering" FontWeight="SemiBold" Margin="0,8,0,0" />
            <RadioButton x:Name="FilterOff" Content="None" GroupName="filter" />
            <RadioButton x:Name="FilterMalware" Content="Block malware (Cloudflare 1.1.1.2)" GroupName="filter" />
            <RadioButton x:Name="FilterFamily" Content="Block malware + adult content (Cloudflare 1.1.1.3)" GroupName="filter" />
            <CheckBox x:Name="BlockDoh" Content="Also block DNS-over-HTTPS bypass" />

            <TextBlock Text="Protection" FontWeight="SemiBold" Margin="0,8,0,0" />
            <CheckBox x:Name="TimeGuard" Content="Time Manipulation Guarding" />
            <CheckBox x:Name="AutoUpdate" Content="Install updates automatically" />

            <TextBlock Text="Change passcode (leave blank to keep)" FontWeight="SemiBold" Margin="0,8,0,0" />
            <Grid ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <PasswordBox x:Name="CurrentPin" Header="Current" MaxLength="4" Grid.Column="0" />
                <PasswordBox x:Name="NewPin" Header="New" MaxLength="4" Grid.Column="1" />
                <PasswordBox x:Name="ConfirmPin" Header="Confirm" MaxLength="4" Grid.Column="2" />
            </Grid>

            <TextBlock x:Name="StatusText" Foreground="#FF4444" Visibility="Collapsed" TextWrapping="Wrap" />
            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right" Margin="0,8,0,0">
                <Button Content="Save" Click="OnSave" />
                <Button Content="Cancel" Click="OnCancel" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
