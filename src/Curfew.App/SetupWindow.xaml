<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Curfew.App.SetupWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel Padding="32" Spacing="14" MaxWidth="480" HorizontalAlignment="Center">
            <TextBlock Text="Set Up Curfew" FontSize="28" FontWeight="Bold" />
            <TextBlock Text="Create an administrator PIN and choose protection options."
                       Opacity="0.7" TextWrapping="Wrap" />

            <TextBlock Text="4-digit PIN" FontWeight="SemiBold" Margin="0,8,0,0" />
            <PasswordBox x:Name="PinBox" MaxLength="4" Width="180" HorizontalAlignment="Left" />
            <TextBlock Text="Confirm PIN" FontWeight="SemiBold" />
            <PasswordBox x:Name="ConfirmBox" MaxLength="4" Width="180" HorizontalAlignment="Left" />

            <TextBlock Text="Content filtering" FontWeight="SemiBold" Margin="0,8,0,0" />
            <RadioButton x:Name="FilterOff" Content="None" GroupName="filter" />
            <RadioButton x:Name="FilterMalware" Content="Block malware (Cloudflare 1.1.1.2)" GroupName="filter" />
            <RadioButton x:Name="FilterFamily" Content="Block malware + adult content (Cloudflare 1.1.1.3)"
                         GroupName="filter" IsChecked="True" />

            <CheckBox x:Name="BlockDoh" Content="Also block DNS-over-HTTPS bypass (recommended)" IsChecked="True" />
            <CheckBox x:Name="TimeGuard" Content="Time Manipulation Guarding (recommended)" IsChecked="True" />

            <TextBlock x:Name="ErrorText" Foreground="#FF4444" Visibility="Collapsed" TextWrapping="Wrap" />
            <Button x:Name="ContinueButton" Content="Continue" Click="OnContinue"
                    HorizontalAlignment="Right" Margin="0,8,0,0" />
        </StackPanel>
    </ScrollViewer>
</Window>
