<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Curfew.App.SetupWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom drag-region title bar so the caption shows the Mica backdrop. -->
        <Grid x:Name="TitleBar" Grid.Row="0" Height="44" Padding="16,0" Background="Transparent">
            <TextBlock Text="Set up Curfew" VerticalAlignment="Center"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </Grid>

        <ScrollViewer Grid.Row="1" Padding="24,8,24,24"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollMode="Disabled">
        <StackPanel Spacing="16" MaxWidth="540" HorizontalAlignment="Center">

            <!-- Hero header -->
            <StackPanel Spacing="8" Margin="0,8,0,8" HorizontalAlignment="Center">
                <Border Width="60" Height="60" CornerRadius="30" HorizontalAlignment="Center"
                        Background="{ThemeResource AccentFillColorDefaultBrush}">
                    <FontIcon Glyph="&#xE916;" FontSize="28"
                              Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" />
                </Border>
                <TextBlock Text="Set up Curfew" Style="{StaticResource TitleTextBlockStyle}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Create an administrator PIN and choose how screen time is enforced. You can fine-tune everything later in Settings."
                           Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap" TextAlignment="Center" MaxWidth="440" />
            </StackPanel>

            <!-- Administrator PIN -->
            <Expander HorizontalAlignment="Stretch" IsExpanded="True" TabIndex="0">
                <Expander.Header>
                    <StackPanel Spacing="2" Padding="0,8">
                        <TextBlock Text="Administrator PIN" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock Text="Required to change settings or unlock the device"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Expander.Header>
                <StackPanel Spacing="12" Padding="0,4,0,8">
                    <PasswordBox x:Name="PinBox"
                                 Header="4-digit PIN"
                                 MaxLength="4"
                                 Width="220"
                                 HorizontalAlignment="Left"
                                 TabIndex="1"
                                 PlaceholderText="••••"
                                 AutomationProperties.Name="Administrator PIN"
                                 AutomationProperties.HelpText="Enter a 4-digit numeric PIN"
                                 ToolTipService.ToolTip="Enter a 4-digit numeric PIN" />
                    <PasswordBox x:Name="ConfirmBox"
                                 Header="Confirm PIN"
                                 MaxLength="4"
                                 Width="220"
                                 HorizontalAlignment="Left"
                                 TabIndex="2"
                                 PlaceholderText="••••"
                                 AutomationProperties.Name="Confirm PIN"
                                 AutomationProperties.HelpText="Re-enter the same 4-digit PIN to confirm"
                                 ToolTipService.ToolTip="Re-enter the same PIN to confirm" />
                </StackPanel>
            </Expander>

            <!-- Time limits -->
            <Expander HorizontalAlignment="Stretch" IsExpanded="True" TabIndex="3">
                <Expander.Header>
                    <StackPanel Spacing="2" Padding="0,8">
                        <TextBlock Text="Time limits" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock Text="Control how long and when the device can be used"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Expander.Header>
                <StackPanel Spacing="16" Padding="0,4,0,8">

                    <!-- Daily limit toggle -->
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="Daily time limit" Style="{StaticResource BodyTextBlockStyle}" />
                            <TextBlock Text="Cap total screen time each day"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleSwitch x:Name="LimitEnabled"
                                      Grid.Column="1"
                                      IsOn="True"
                                      VerticalAlignment="Center"
                                      TabIndex="4"
                                      AutomationProperties.Name="Enforce a daily time limit"
                                      ToolTipService.ToolTip="Enforce a daily time limit" />
                    </Grid>

                    <NumberBox x:Name="HoursPerDay"
                               Header="Hours per day"
                               Minimum="0"
                               Maximum="24"
                               SmallChange="0.25"
                               Value="2"
                               SpinButtonPlacementMode="Inline"
                               Width="220"
                               HorizontalAlignment="Left"
                               TabIndex="5"
                               AutomationProperties.Name="Hours allowed per day"
                               AutomationProperties.HelpText="You can fine-tune the limit for each weekday later in Settings"
                               ToolTipService.ToolTip="Applied to every weekday — fine-tune per day later in Settings" />

                    <!-- Weekly schedule toggle -->
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="Weekly schedule" Style="{StaticResource BodyTextBlockStyle}" />
                            <TextBlock Text="Only allow usage during painted time windows — set the grid in Settings"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleSwitch x:Name="ScheduleEnabled"
                                      Grid.Column="1"
                                      VerticalAlignment="Center"
                                      TabIndex="6"
                                      AutomationProperties.Name="Enforce a weekly schedule"
                                      ToolTipService.ToolTip="Enforce a weekly schedule (set the grid in Settings)" />
                    </Grid>
                </StackPanel>
            </Expander>

            <!-- Content filtering -->
            <Expander HorizontalAlignment="Stretch" TabIndex="7">
                <Expander.Header>
                    <StackPanel Spacing="2" Padding="0,8">
                        <TextBlock Text="Content filtering" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock Text="Filter unwanted sites at the DNS level using Cloudflare"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Expander.Header>
                <StackPanel Spacing="12" Padding="0,4,0,8">
                    <RadioButtons x:Name="FilterChoices"
                                  Header="Filter level"
                                  TabIndex="8"
                                  AutomationProperties.Name="Content filter level">
                        <RadioButton x:Name="FilterOff"
                                     Content="None"
                                     GroupName="filter"
                                     ToolTipService.ToolTip="No DNS filtering" />
                        <RadioButton x:Name="FilterMalware"
                                     Content="Block malware (Cloudflare 1.1.1.2)"
                                     GroupName="filter"
                                     ToolTipService.ToolTip="Blocks known malware domains" />
                        <RadioButton x:Name="FilterFamily"
                                     Content="Block malware and adult content (Cloudflare 1.1.1.3)"
                                     GroupName="filter"
                                     IsChecked="True"
                                     ToolTipService.ToolTip="Blocks malware plus adult content" />
                    </RadioButtons>

                    <Grid ColumnSpacing="16" Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="Block DNS-over-HTTPS bypass" Style="{StaticResource BodyTextBlockStyle}" />
                            <TextBlock Text="Prevents apps from sidestepping the content filter"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleSwitch x:Name="BlockDoh"
                                      Grid.Column="1"
                                      IsOn="True"
                                      VerticalAlignment="Center"
                                      TabIndex="9"
                                      AutomationProperties.Name="Block DNS-over-HTTPS bypass"
                                      ToolTipService.ToolTip="Also block DNS-over-HTTPS bypass" />
                    </Grid>
                </StackPanel>
            </Expander>

            <!-- Protection -->
            <Expander HorizontalAlignment="Stretch" TabIndex="10">
                <Expander.Header>
                    <StackPanel Spacing="2" Padding="0,8">
                        <TextBlock Text="Protection" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock Text="Guard against attempts to bypass enforcement"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Expander.Header>
                <Grid ColumnSpacing="16" Padding="0,4,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="Time Manipulation Guarding" Style="{StaticResource BodyTextBlockStyle}" />
                        <TextBlock Text="Detects and reverses clock changes used to dodge limits"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <ToggleSwitch x:Name="TimeGuard"
                                  Grid.Column="1"
                                  IsOn="True"
                                  VerticalAlignment="Center"
                                  TabIndex="11"
                                  AutomationProperties.Name="Time Manipulation Guarding"
                                  ToolTipService.ToolTip="Time Manipulation Guarding" />
                </Grid>
            </Expander>

            <!-- Error + primary action -->
            <TextBlock x:Name="ErrorText"
                       Style="{StaticResource BodyStrongTextBlockStyle}"
                       Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                       TextWrapping="Wrap"
                       Visibility="Collapsed"
                       Margin="0,4,0,0"
                       AutomationProperties.LiveSetting="Assertive" />

            <Button x:Name="ContinueButton"
                    Content="Continue"
                    Style="{StaticResource AccentButtonStyle}"
                    Click="OnContinue"
                    HorizontalAlignment="Right"
                    MinWidth="120"
                    TabIndex="12"
                    Margin="0,4,0,0"
                    AutomationProperties.Name="Continue and save setup" />
        </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
