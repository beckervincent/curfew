<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Curfew.App.SetupWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Padding="28,20,28,28">
        <StackPanel Spacing="14" MaxWidth="520" HorizontalAlignment="Center">
            <TextBlock Text="Set Up Curfew" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Text="Create an administrator PIN and choose how screen time is enforced."
                       Opacity="0.7" TextWrapping="Wrap" />

            <Expander HorizontalAlignment="Stretch" IsExpanded="True">
                <Expander.Header><TextBlock Text="Administrator PIN" /></Expander.Header>
                <StackPanel Spacing="10" Padding="0,8,0,0">
                    <PasswordBox x:Name="PinBox" Header="4-digit PIN" MaxLength="4" Width="200" HorizontalAlignment="Left" />
                    <PasswordBox x:Name="ConfirmBox" Header="Confirm PIN" MaxLength="4" Width="200" HorizontalAlignment="Left" />
                </StackPanel>
            </Expander>

            <Expander HorizontalAlignment="Stretch" IsExpanded="True">
                <Expander.Header><TextBlock Text="Time limits" /></Expander.Header>
                <StackPanel Spacing="10" Padding="0,8,0,0">
                    <ToggleSwitch x:Name="LimitEnabled" Header="Enforce a daily time limit" IsOn="True" />
                    <NumberBox x:Name="HoursPerDay" Header="Hours per day (you can fine-tune each day later)"
                               Minimum="0" Maximum="24" SmallChange="0.25" Value="2"
                               Width="220" HorizontalAlignment="Left" />
                    <ToggleSwitch x:Name="ScheduleEnabled" Header="Enforce a weekly schedule (set the grid in Settings)" />
                </StackPanel>
            </Expander>

            <Expander HorizontalAlignment="Stretch">
                <Expander.Header><TextBlock Text="Content filtering" /></Expander.Header>
                <StackPanel Spacing="6" Padding="0,8,0,0">
                    <RadioButton x:Name="FilterOff" Content="None" GroupName="filter" />
                    <RadioButton x:Name="FilterMalware" Content="Block malware (Cloudflare 1.1.1.2)" GroupName="filter" />
                    <RadioButton x:Name="FilterFamily" Content="Block malware + adult content (Cloudflare 1.1.1.3)"
                                 GroupName="filter" IsChecked="True" />
                    <ToggleSwitch x:Name="BlockDoh" Header="Also block DNS-over-HTTPS bypass" IsOn="True" />
                </StackPanel>
            </Expander>

            <Expander HorizontalAlignment="Stretch">
                <Expander.Header><TextBlock Text="Protection" /></Expander.Header>
                <ToggleSwitch x:Name="TimeGuard" Header="Time Manipulation Guarding" IsOn="True" Margin="0,8,0,0" />
            </Expander>

            <TextBlock x:Name="ErrorText" Foreground="#FF4444" Visibility="Collapsed" TextWrapping="Wrap" />
            <Button x:Name="ContinueButton" Content="Continue" Style="{StaticResource AccentButtonStyle}"
                    Click="OnContinue" HorizontalAlignment="Right" Margin="0,8,0,0" />
        </StackPanel>
    </ScrollViewer>
</Window>
