<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Curfew.App.SetupWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Curfew.App">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom drag-region title bar so the caption shows the Mica backdrop. -->
        <Grid x:Name="TitleBar" Grid.Row="0" Height="44" Padding="16,0" Background="Transparent">
            <TextBlock Text="{local:Loc Key=setup.title}" VerticalAlignment="Center"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </Grid>

        <ScrollViewer Grid.Row="1" Padding="24,8,24,24"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollMode="Disabled">
        <StackPanel Spacing="16" MaxWidth="540" HorizontalAlignment="Center">

            <!-- Hero header -->
            <StackPanel Spacing="8" Margin="0,8,0,8" HorizontalAlignment="Center">
                <Border Width="60" Height="60" CornerRadius="30" HorizontalAlignment="Center"
                        Background="{ThemeResource AccentFillColorDefaultBrush}">
                    <FontIcon Glyph="&#xE916;" FontSize="28"
                              Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" />
                </Border>
                <TextBlock Text="{local:Loc Key=setup.title}" Style="{StaticResource TitleTextBlockStyle}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="{local:Loc Key=setup.subtitle}"
                           Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap" TextAlignment="Center" MaxWidth="440" />
            </StackPanel>

            <!-- Administrator PIN -->
            <Expander HorizontalAlignment="Stretch" IsExpanded="True" TabIndex="0">
                <Expander.Header>
                    <StackPanel Spacing="2" Padding="0,8">
                        <TextBlock Text="{local:Loc Key=setup.pin.header}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock Text="{local:Loc Key=setup.pin.desc}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Expander.Header>
                <StackPanel Spacing="12" Padding="0,4,0,8">
                    <PasswordBox x:Name="PinBox"
                                 Header="{local:Loc Key=setup.pin.field}"
                                 MaxLength="64"
                                 Width="220"
                                 HorizontalAlignment="Left"
                                 TabIndex="1"
                                 PlaceholderText="••••"
                                 AutomationProperties.Name="Administrator PIN"
                                 AutomationProperties.HelpText="Enter a PIN or password"
                                 ToolTipService.ToolTip="Enter a PIN or password" />
                    <PasswordBox x:Name="ConfirmBox"
                                 Header="{local:Loc Key=setup.pin.confirm}"
                                 MaxLength="64"
                                 Width="220"
                                 HorizontalAlignment="Left"
                                 TabIndex="2"
                                 PlaceholderText="••••"
                                 AutomationProperties.Name="Confirm PIN"
                                 AutomationProperties.HelpText="Re-enter the same PIN or password to confirm"
                                 ToolTipService.ToolTip="Re-enter the same PIN or password to confirm" />
                </StackPanel>
            </Expander>

            <!-- Time limits -->
            <Expander HorizontalAlignment="Stretch" IsExpanded="True" TabIndex="3">
                <Expander.Header>
                    <StackPanel Spacing="2" Padding="0,8">
                        <TextBlock Text="{local:Loc Key=setup.limits.header}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock Text="{local:Loc Key=setup.limits.desc}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Expander.Header>
                <StackPanel Spacing="16" Padding="0,4,0,8">

                    <!-- Daily limit toggle -->
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="{local:Loc Key=setup.daily.title}" Style="{StaticResource BodyTextBlockStyle}" />
                            <TextBlock Text="{local:Loc Key=setup.daily.desc}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleSwitch x:Name="LimitEnabled"
                                      Grid.Column="1"
                                      IsOn="True"
                                      VerticalAlignment="Center"
                                      TabIndex="4"
                                      AutomationProperties.Name="Enforce a daily time limit"
                                      ToolTipService.ToolTip="Enforce a daily time limit" />
                    </Grid>

                    <NumberBox x:Name="HoursPerDay"
                               Header="{local:Loc Key=setup.hours}"
                               Minimum="0"
                               Maximum="24"
                               SmallChange="0.25"
                               Value="2"
                               SpinButtonPlacementMode="Inline"
                               Width="220"
                               HorizontalAlignment="Left"
                               TabIndex="5"
                               AutomationProperties.Name="Hours allowed per day"
                               AutomationProperties.HelpText="You can fine-tune the limit for each weekday later in Settings"
                               ToolTipService.ToolTip="Applied to every weekday — fine-tune per day later in Settings" />

                    <!-- Weekly schedule toggle -->
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="{local:Loc Key=setup.schedule.title}" Style="{StaticResource BodyTextBlockStyle}" />
                            <TextBlock Text="{local:Loc Key=setup.schedule.desc}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleSwitch x:Name="ScheduleEnabled"
                                      Grid.Column="1"
                                      VerticalAlignment="Center"
                                      TabIndex="6"
                                      AutomationProperties.Name="Enforce a weekly schedule"
                                      ToolTipService.ToolTip="Enforce a weekly schedule (paint the grid under Advanced)" />
                    </Grid>

                    <!-- Advanced: a per-day limit for each weekday plus the weekly schedule grid -->
                    <Button x:Name="AdvancedButton"
                            Content="{local:Loc Key=setup.advanced}"
                            Click="OnToggleAdvanced"
                            HorizontalAlignment="Left"
                            TabIndex="7"
                            AutomationProperties.Name="Show advanced time-limit options" />
                    <StackPanel x:Name="AdvancedPanel" Spacing="16" Visibility="Collapsed">
                        <StackPanel Spacing="8">
                            <TextBlock Text="{local:Loc Key=setup.perday.hint}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap" />
                            <StackPanel x:Name="DailyPerDayPanel" Spacing="12" />
                        </StackPanel>
                        <local:ScheduleGrid x:Name="ScheduleGridControl" Height="300" HorizontalAlignment="Stretch"
                                            AutomationProperties.Name="Weekly allowed-time schedule grid" />
                    </StackPanel>
                </StackPanel>
            </Expander>

            <!-- Content filtering -->
            <Expander HorizontalAlignment="Stretch" TabIndex="8">
                <Expander.Header>
                    <StackPanel Spacing="2" Padding="0,8">
                        <TextBlock Text="{local:Loc Key=setup.filter.header}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock Text="{local:Loc Key=setup.filter.desc}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Expander.Header>
                <StackPanel Spacing="12" Padding="0,4,0,8">
                    <RadioButtons x:Name="FilterChoices"
                                  Header="{local:Loc Key=setup.filter.level}"
                                  TabIndex="9"
                                  AutomationProperties.Name="Content filter level">
                        <RadioButton x:Name="FilterOff"
                                     Content="{local:Loc Key=filter.none}"
                                     GroupName="filter"
                                     ToolTipService.ToolTip="No DNS filtering" />
                        <RadioButton x:Name="FilterMalware"
                                     Content="{local:Loc Key=filter.malware}"
                                     GroupName="filter"
                                     ToolTipService.ToolTip="Blocks known malware domains" />
                        <RadioButton x:Name="FilterFamily"
                                     Content="{local:Loc Key=filter.family}"
                                     GroupName="filter"
                                     IsChecked="True"
                                     ToolTipService.ToolTip="Blocks malware plus adult content" />
                    </RadioButtons>

                    <Grid ColumnSpacing="16" Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="{local:Loc Key=setup.doh.title}" Style="{StaticResource BodyTextBlockStyle}" />
                            <TextBlock Text="{local:Loc Key=setup.doh.desc}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleSwitch x:Name="BlockDoh"
                                      Grid.Column="1"
                                      IsOn="True"
                                      VerticalAlignment="Center"
                                      TabIndex="10"
                                      AutomationProperties.Name="Block DNS-over-HTTPS bypass"
                                      ToolTipService.ToolTip="Also block DNS-over-HTTPS bypass" />
                    </Grid>
                </StackPanel>
            </Expander>

            <!-- Protection -->
            <Expander HorizontalAlignment="Stretch" TabIndex="11">
                <Expander.Header>
                    <StackPanel Spacing="2" Padding="0,8">
                        <TextBlock Text="{local:Loc Key=setup.protection.header}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock Text="{local:Loc Key=setup.protection.desc}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Expander.Header>
                <Grid ColumnSpacing="16" Padding="0,4,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="{local:Loc Key=setup.timeguard.title}" Style="{StaticResource BodyTextBlockStyle}" />
                        <TextBlock Text="{local:Loc Key=setup.timeguard.desc}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <ToggleSwitch x:Name="TimeGuard"
                                  Grid.Column="1"
                                  IsOn="True"
                                  VerticalAlignment="Center"
                                  TabIndex="12"
                                  AutomationProperties.Name="Time Manipulation Guarding"
                                  ToolTipService.ToolTip="Time Manipulation Guarding" />
                </Grid>
            </Expander>

            <!-- Error + primary action -->
            <TextBlock x:Name="ErrorText"
                       Style="{StaticResource BodyStrongTextBlockStyle}"
                       Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                       TextWrapping="Wrap"
                       Visibility="Collapsed"
                       Margin="0,4,0,0"
                       AutomationProperties.LiveSetting="Assertive" />

            <Button x:Name="ContinueButton"
                    Content="{local:Loc Key=setup.continue}"
                    Style="{StaticResource AccentButtonStyle}"
                    Click="OnContinue"
                    HorizontalAlignment="Right"
                    MinWidth="120"
                    TabIndex="13"
                    Margin="0,4,0,0"
                    AutomationProperties.Name="Continue and save setup" />
        </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
