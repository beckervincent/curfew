<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Curfew.App.PasscodeWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid x:Name="TitleBar" Grid.Row="0" Height="44" Padding="16,0" Background="Transparent">
            <TextBlock Text="Curfew" VerticalAlignment="Center"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </Grid>

        <Grid Grid.Row="1" Padding="24">
        <Border MaxWidth="360"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="24"
                CornerRadius="8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1">
            <StackPanel Spacing="16">

                <!-- Header -->
                <StackPanel Spacing="4" HorizontalAlignment="Center">
                    <FontIcon Glyph="&#xE72E;"
                              FontSize="28"
                              Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                              HorizontalAlignment="Center" />
                    <TextBlock Text="Enter passcode"
                               Style="{StaticResource SubtitleTextBlockStyle}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Enter your 4-digit PIN to continue."
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <!-- PIN input -->
                <PasswordBox x:Name="PinBox"
                             MaxLength="4"
                             Width="200"
                             HorizontalAlignment="Center"
                             PlaceholderText="••••"
                             TabIndex="0"
                             KeyDown="OnKeyDown"
                             AutomationProperties.Name="Passcode"
                             AutomationProperties.HelpText="Enter your 4-digit PIN, then press Enter or select OK."
                             ToolTipService.ToolTip="4-digit PIN" />

                <!-- Inline error -->
                <InfoBar x:Name="ErrorText"
                         Severity="Error"
                         IsOpen="True"
                         IsClosable="False"
                         Title="Incorrect passcode"
                         Message="Please check the PIN and try again."
                         Visibility="Collapsed" />

                <!-- Actions -->
                <StackPanel Orientation="Horizontal"
                            Spacing="8"
                            HorizontalAlignment="Right">
                    <Button Content="Cancel"
                            MinWidth="96"
                            TabIndex="2"
                            Click="OnCancel" />
                    <Button Content="OK"
                            MinWidth="96"
                            TabIndex="1"
                            Style="{StaticResource AccentButtonStyle}"
                            Click="OnOk" />
                </StackPanel>

            </StackPanel>
        </Border>
        </Grid>
    </Grid>
</Window>
