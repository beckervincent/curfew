<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Curfew.App.PasscodeWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="28">
        <StackPanel Spacing="14" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="320">
            <TextBlock Text="Enter Passcode" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" />
            <TextBlock Text="Enter your 4-digit PIN to continue." Opacity="0.7" HorizontalAlignment="Center" />
            <PasswordBox x:Name="PinBox" MaxLength="4" Width="180" HorizontalAlignment="Center"
                         KeyDown="OnKeyDown" />
            <TextBlock x:Name="ErrorText" Text="Incorrect passcode." Foreground="#FF4444"
                       HorizontalAlignment="Center" Visibility="Collapsed" />
            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                <Button Content="OK" Click="OnOk" />
                <Button Content="Cancel" Click="OnCancel" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
