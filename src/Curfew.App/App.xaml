<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="Curfew.App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!--
                    WinUI 3 Fluent control templates and theme styles
                    (TitleTextBlockStyle, CaptionTextBlockStyle, AccentButtonStyle,
                    the *FillColorBrush tokens, …). Required for controls to render;
                    must stay first.
                -->
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!--
                Windows 11 rounded-corner system, applied implicitly to every control
                template (Button, TextBox, NumberBox, Expander, flyouts, cards, …) and
                overlay surface. We deliberately do not set Application.RequestedTheme,
                so the app follows the system light/dark setting and stays Mica-friendly.
            -->
            <CornerRadius x:Key="ControlCornerRadius">6</CornerRadius>
            <CornerRadius x:Key="OverlayCornerRadius">8</CornerRadius>
        </ResourceDictionary>
    </Application.Resources>
</Application>
