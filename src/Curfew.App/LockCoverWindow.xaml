<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Curfew.App.LockCoverWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Curfew.App">

    <!-- Secondary-monitor cover: nothing interactive except the failover button
         that pulls the primary lock card onto this display. -->
    <Grid Background="#000000" RequestedTheme="Dark">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="24">
            <FontIcon Glyph="&#xE72E;"
                      FontSize="96"
                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                      HorizontalAlignment="Center" />
            <TextBlock Text="{local:Loc Key=lock.secondary.caption}"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center" />
            <Button Content="{local:Loc Key=lock.move.here}"
                    HorizontalAlignment="Center"
                    Style="{StaticResource AccentButtonStyle}"
                    Click="OnMoveHere" />
        </StackPanel>
    </Grid>
</Window>
